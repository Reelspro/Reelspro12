# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=your-secret-key-here-change-this

# ─── AI Providers (add your keys) ───────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ─── Redis (optional - for BullMQ queues) ────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── FFmpeg ──────────────────────────────────────────
# Leave empty to use bundled ffmpeg-static
FFMPEG_PATH=

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Auto-Update (GitHub repo details) ───────────────
# Format: username/reponame
GITHUB_REPO=YourGitHubUsername/reelspro-v12

# ─── App URL (for short links) ───────────────────────
APP_URL=http://localhost:5000
